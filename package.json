{
  "name": "pipeOrgans_frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "watch": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint --ext .js,.vue src",
    "lint:watch": "npx chokidar \"src/**/*.{js,vue}\" -c \"npx eslint --ext .js,.vue src\"",
    "format": "prettier --write \"src/**/*.{js,vue}\"",
    "clean": "rimraf dist node_modules package-lock.json",
    "reinstall": "npm run clean && npm install --legacy-peer-deps",
    "test": "vitest",
    "test:watch": "vitest --watch"
  },
  "engines": {
    "node": ">=20.0.0 <21"
  },
  "dependencies": {
    "axios": "^1.3.4",
    "core-js": "^3.8.3",
    "pinia": "^2.3.1",
    "vue": "^3.5.27",
    "vue-loader": "^17.4.2",
    "vue-router": "^4.6.4",
    "vue-svg-loader": "^0.10.0",
    "vuetify": "^3.11.8",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@mdi/font": "^7.4.47",
    "@types/node": "^20.19.00",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/test-utils": "^2.4.6",
    "chokidar-cli": "^3.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^6.15.0",
    "eslint-config-standard": "^16.0.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^15.6.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^3.4.1",
    "eslint-plugin-promise": "^5.1.1",
    "eslint-plugin-vue": "^7.20.0",
    "jsdom": "^28.0.0",
    "prettier": "^2.8.8",
    "rimraf": "^6.0.1",
    "sass": "^1.97.3",
    "sass-loader": "^13.3.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.1.2",
    "typescript": "^5.0.2",
    "vite": "^7.3.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.0.18",
    "vue-loader": "^17.4.2",
    "vuetify": "^3.11.8"
  }
}
