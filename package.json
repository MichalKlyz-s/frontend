{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--openssl-legacy-provider vue-cli-service serve",
    "serve": "npm run dev",
    "build": "vue-cli-service build",
    "lint": "vue-cli-service lint --no-fix",
    "lint:fix": "vue-cli-service lint --fix",
    "lint:watch": "npx chokidar \"src/**/*.{js,vue}\" -c \"npx eslint --ext .js,.vue src\"",
    "format": "prettier --write \"src/**/*.{js,vue}\"",
    "analyze": "vue-cli-service build --report",
    "clean": "rimraf dist node_modules package-lock.json",
    "reinstall": "npm run clean && npm install --legacy-peer-deps",
    "watch": "cross-env NODE_OPTIONS=--openssl-legacy-provider vue-cli-service serve --watch"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "axios": "^1.3.4",
    "babel-preset-es2015": "^6.24.1",
    "core-js": "^3.8.3",
    "fast-async": "^6.3.8",
    "stylus-loader": "^7.1.0",
    "vue": "^2.7.14",
    "vue-router": "^3.5.1",
    "vue-svg-loader": "^0.12.0",
    "vuetify": "^2.6.14",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@types/node": "^18.15.10",
    "@types/webpack": "^5.28.1",
    "@types/webpack-dev-server": "^4.7.2",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-plugin-router": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "babel-plugin-transform-async-to-promises": "^0.8.18",
    "chokidar-cli": "^3.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^6.15.0",
    "eslint-config-standard": "^16.0.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^15.6.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^3.4.1",
    "eslint-plugin-promise": "^5.1.1",
    "eslint-plugin-vue": "^7.20.0",
    "eslint-webpack-plugin": "^2.5.4",
    "prettier": "^2.8.8",
    "rimraf": "^6.0.1",
    "sass": "~1.32.0",
    "sass-loader": "^10.0.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.1.2",
    "typescript": "^5.0.2",
    "vue-cli-plugin-vuetify": "~2.5.8",
    "vue-template-compiler": "^2.6.14",
    "vuetify-loader": "^1.7.0",
    "webpack-env": "^0.8.0"
  },
  "eslintConfig": {
    "rules": {
      "vue/max-attributes-per-line": [
        "error",
        {
          "singleline": 5,
          "multiline": {
            "max": 5,
            "allowFirstLine": true
          }
        }
      ]
    },
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "@babel/eslint-parser"
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
